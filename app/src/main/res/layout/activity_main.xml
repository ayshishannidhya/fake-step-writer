<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#121212">

    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/ic_app_logo"
        android:contentDescription="Step Writer Logo"
        android:scaleType="centerCrop"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step Writer"
        android:textSize="32sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Write steps directly to Health Connect"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/editStepCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter step count"
        android:text="20000"
        android:inputType="number"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:gravity="center"
        android:background="@drawable/edit_bg"
        android:padding="16dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnWriteSteps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📝 WRITE STEPS TO HEALTH CONNECT"
        android:textSize="16sp"
        android:padding="16dp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnReadSteps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 READ TODAY'S STEPS"
        android:textSize="14sp"
        android:padding="12dp"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Ready. Grant permissions when prompted."
        android:textSize="14sp"
        android:textColor="#CCCCCC"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Made by Ayshi Shannidhya Panda (Ankit)"
        android:textSize="12sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-light" />

</LinearLayout>

